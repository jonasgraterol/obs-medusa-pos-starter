{
  "expo": {
    "name": "OBS Jeans POS",
    "slug": "obs-jeans-pos",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "obsjeans",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "ios": {
      "bundleIdentifier": "com.obsjeans.pos",
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#1C1917"
      },
      "edgeToEdgeEnabled": true,
      "softwareKeyboardLayoutMode": "pan",
      "package": "com.obsjeans.pos"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 280,
          "resizeMode": "contain",
          "backgroundColor": "#f9f9f9"
        }
      ],
      [
        "expo-secure-store",
        {
          "configureAndroidBackup": true,
          "faceIDPermission": "Permitir a $(PRODUCT_NAME) acceder a tus datos biométricos de Face ID."
        }
      ],
      [
        "expo-font",
        {
          "fonts": [
            "node_modules/@expo-google-fonts/noto-sans/400Regular/NotoSans_400Regular.ttf",
            "node_modules/@expo-google-fonts/noto-sans/400Regular_Italic/NotoSans_400Regular_Italic.ttf",
            "node_modules/@expo-google-fonts/noto-sans/700Bold/NotoSans_700Bold.ttf",
            "node_modules/@expo-google-fonts/noto-sans/700Bold_Italic/NotoSans_700Bold_Italic.ttf"
          ]
        }
      ],
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "2c44b68b-5c32-4031-a160-d315e6c399d4"
      }
    },
    "owner": "obs-jeans",
    "runtimeVersion": "1.0.0",
    "updates": {
      "url": "https://u.expo.dev/2c44b68b-5c32-4031-a160-d315e6c399d4"
    }
  }
}
